# ── Required ──────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_PEPPER=replace-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ── CSRF Protection ───────────────────────────────────────────────────────
# Used to sign CSRF tokens. If omitted, a hardcoded fallback is used
# (acceptable for dev but set a unique value in production).
CSRF_SALT=replace-with-a-random-string

# ── Firebase Web SDK (public — used client-side for Google sign-in) ───────
# NOTE: Firebase auth has been replaced by Supabase. These are kept only if
# Firestore is still used for data persistence on Vercel.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side — required for Firestore persistence) ──
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Supabase Auth (replaces Firebase for Google sign-in) ──────────────────
# Public client values (safe to expose to the browser).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side secret used to verify Supabase access tokens (HS256). Keep this
# secret — it lives in Project Settings > API > JWT Secret.
SUPABASE_JWT_SECRET=
# Service-role key used by the server to persist users into Supabase Postgres
# (works on Vercel/serverless where the local filesystem is read-only).
# Project Settings > API > service_role key. Keep secret — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional / External APIs ──────────────────────────────────────────────
# Code execution (Judge0 / JDOODLE)
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
# AI features
GEMINI_API_KEY=
